{
  "name": "wish-parser",
  "version": "1.1.0",
  "author": "Rustam Yusupov",
  "description": "Price parsing service for wishlist",
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --watch src/index.ts",
    "start": "node src/index.ts",
    "check": "tsc --noEmit",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/autoload": "6.3.1",
    "fastify": "5.10.0",
    "fastify-plugin": "6.0.0",
    "fastify-type-provider-zod": "7.0.0",
    "playwright": "1.61.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.2",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  },
  "imports": {
    "#*": "./src/*.ts"
  },
  "engines": {
    "node": "24.x"
  }
}
