{
  "name": "wish-parser",
  "version": "1.0.0",
  "author": "Rustam Yusupov",
  "description": "Nightly price parser for wishlist",
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "playwright": "1.61.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.13.2",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.9.4",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": "24.x"
  }
}
